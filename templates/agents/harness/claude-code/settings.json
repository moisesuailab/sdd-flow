{
  "permissions": {
    "deny": [
      "Bash(git push*)",
      "Bash(git tag*)",
      "Bash(git branch -d*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "bash agents/harness/claude-code/.hooks/guard-git.sh"
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "bash agents/harness/claude-code/.hooks/guard-delete.sh"
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "bash agents/harness/claude-code/.hooks/guard-deps.sh"
        }]
      }
    ]
  }
}